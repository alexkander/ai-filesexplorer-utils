{
  "name": "ai-filesexplorer-utils",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
  "mounts": [
    "source=ai-filesexplorer-utils-node_modules,target=/app/node_modules,type=volume",
    "source=ai-filesexplorer-utils-next,target=/app/.next,type=volume",
    "source=/thezone,target=/thezone,type=bind,consistency=cached"
  ],
  "containerEnv": { "WATCHPACK_POLLING": "true" },
  "runArgs": ["--network=host"],
  "remoteUser": "node",
  "postCreateCommand": "sudo chown node:node /app/node_modules /app/.next && git config --global --add safe.directory /app && npm install --global pnpm@$(node -p \"require('./package.json').packageManager.split('@')[1]\") && pnpm install --frozen-lockfile",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  }
}
