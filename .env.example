# Copy to .env and adjust for this machine — docker-compose.yml and
# docker-compose.prod.yml read it automatically for variable substitution.

# Host path bind-mounted into the container at /thezone (the app's browsable
# filesystem root). Defaults to /thezone if unset.
MYFILES=/myfiles

# Port the app listens on — read natively by `next dev`/`next start` (and the
# production standalone server) via their own PORT env var support, and
# threaded through docker-compose.yml/docker-compose.prod.yml's port mapping
# and the Dockerfile's EXPOSE. Defaults to 3000 if unset.
PORT=3000
