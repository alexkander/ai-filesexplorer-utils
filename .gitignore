# Count and size tool — SQLite persistence (specs/002-count-and-size).
# The directory itself is tracked (see data/.gitkeep) so it exists on a
# fresh clone for the docker-compose bind mount; only its contents are
# ignored.
data/*
!data/.gitkeep
